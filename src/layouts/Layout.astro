---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
	title?: string;
}

const { title = "Flamarion Fagundes Pinto - Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Portfólio de Flamarion Fagundes Pinto. Desenvolvedor Fullstack especialista em arquitetura de alto desempenho." />
		<title>{title}</title>
	<body class="max-w-[1280px] w-full mx-auto">
		<slot />
		<Analytics />
	</body>
</html>
