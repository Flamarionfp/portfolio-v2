---
import { DiAndroid, DiReact, DiNodejsSmall, DiDocker, DiPostgresql, DiNginx } from "react-icons/di";

const iconMap: Record<string, any> = {
  "Android": DiAndroid,
  "React": DiReact,
  "Node.js": DiNodejsSmall,
  "Docker": DiDocker,
  "PostgreSQL": DiPostgresql,
  "Nginx": DiNginx,
};

const projects = [
  {
    title: "Lighthouse IT",
    description: "Minha experiência na Lighthouse tem me proporcionado a oportunidade de trabalhar em diversos projetos desafiadores, incluindo aplicações em React Native para redes sociais, bancos e e-commerce no setor farmacêutico. Também participo do desenvolvimento de dashboards administrativos que otimizam a análise de dados e a tomada de decisões. Além disso, atuo em e-commerces web fullstack, aplicando minhas habilidades em frontend e backend para garantir uma experiência de usuário fluida e eficiente. Essa vivência me permite aprimorar continuamente minha versatilidade técnica e aprofundar meu conhecimento em diferentes áreas, sempre focando em soluções inovadoras e eficazes.",
    image: "/images/lighthouse_ti_logo.jpeg",
    tags: ["Android", "React", "Node.js", "Docker", "PostgreSQL"],
    id: 0,
  },
  {
    title: "Fofão Lanches",
    description: "Este projeto de sistema de pontos de fidelidade para uma lancheria foi desenvolvido para aprimorar a experiência do cliente e a gestão administrativa. Nele, os clientes podem registrar os valores gastos, que são submetidos para aprovação do administrador. Uma vez aprovados, os clientes têm a opção de resgatar lanches cadastrados, incluindo nome, preço e imagens hospedadas no Cloudflare. A plataforma ainda conta com integração ao WhatsApp, facilitando a comunicação. Utilizando tecnologias como Next.js, Node.js, PostgreSQL e Prisma, o design responsivo garante uma experiência otimizada em diversos dispositivos, promovendo um relacionamento mais interativo e recompensador entre a lancheria e seus clientes.",
    image: "/images/fofao_lanches_logo.jpg",
    tags: ["React", "Node.js", "Docker", "PostgreSQL", "Nginx"],
    id: 1,
  },
];
---

<section id="projects" class="flex flex-col mx-auto max-w-[1040px] px-12 pt-8 box-content relative max-md:px-12 max-sm:px-4 max-sm:pt-4">
  <div class="w-[64px] h-[6px] rounded-[10px] bg-gradient-to-l from-[#13ADC7] to-[#945DD6] my-[4rem] max-md:w-[48px] max-md:h-[4px] max-sm:w-[32px] max-sm:h-[2px] max-sm:my-[2rem]"></div>
  <h2 class="font-extrabold text-[65px] leading-[72px] w-max max-w-full bg-clip-text text-transparent bg-gradient-to-br from-white to-white/60 mb-4 py-14 max-md:text-[56px] max-md:leading-[56px] max-md:py-10 max-sm:text-[32px] max-sm:leading-[40px] max-sm:py-2 max-sm:mb-0">Projetos</h2>
  
  <div class="grid grid-cols-[repeat(auto-fill,minmax(400px,1fr))] p-[3rem] place-items-center gap-x-[2rem] gap-y-[3rem] max-sm:flex max-sm:flex-col max-sm:px-0 max-sm:py-4 max-sm:pb-[25px]">
    {projects.map((p) => (
      <div class="rounded-[10px] shadow-[3px_3px_20px_rgba(80,78,78,0.5)] text-center w-[400px] h-full flex flex-col bg-[#0f1624] overflow-hidden max-sm:w-full">
        <!-- Kept original layout height behavior -->
        <img src={p.image} alt={p.title} class="w-full object-cover" loading="lazy" />
        <div class="text-center z-20 w-full mt-4">
          <h3 class="font-medium tracking-[2px] text-[#9cc9e3] py-[0.5rem] text-[30px]">{p.title}</h3>
          <hr class="w-[50px] h-[3px] my-[20px] mx-auto border-0 bg-[#d0bb57]" />
        </div>
        <p class="w-full px-[50px] text-[#e4e6e7] text-[16px] leading-[24px] text-left max-sm:px-[25px] flex-grow">
          {p.description}
        </p>
        <div class="mt-[25px]">
          <div class="text-center z-20 w-full text-white text-[20px]">Stack</div>
          <ul class="flex justify-around p-[2rem]">
            {p.tags.map((tag) => {
              const IconComp = iconMap[tag];
              return (
                <li class="h-[25px] w-[25px] flex items-center justify-center text-white" title={tag}>
                  {IconComp ? <IconComp size={25} /> : <span class="text-[10px] text-white/80 border border-white/20 rounded-full w-full h-full flex items-center justify-center">{tag.substring(0, 1)}</span>}
                </li>
              );
            })}
          </ul>
        </div>
      </div>
    ))}
  </div>
</section>
